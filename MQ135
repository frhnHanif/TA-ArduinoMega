#include <Arduino.h>
#define MQ135_A0 A0
#define MQ135_D0 7

void setup() {
  Serial.begin(115200);
  
  pinMode(MQ135_D0, INPUT);

  Serial.println("Monitoring MQ-135 (Analog + Digital)...");
}

void loop() {
  // Baca analog
  int nilaiGas = analogRead(MQ135_A0);

  // Baca digital
  int statusGas = digitalRead(MQ135_D0);

  // Tampilkan analog
  Serial.print("Nilai Gas (A0): ");
  Serial.print(nilaiGas);

  // Tampilkan digital
  Serial.print(" | Status (D0): ");
  
  if (statusGas == LOW) {
    Serial.println("Gas Terdeteksi!");
  } else {
    Serial.println("Aman");
  }

  delay(1000);
}