#include <Arduino.h>
#include "HX711_ADC.h"

const int HX711_dout = 2;
const int HX711_sck = 4;

HX711_ADC LoadCell(HX711_dout, HX711_sck);

// 🔥 GANTI dengan hasil kalibrasi kamu
const float calibrationFactor = 131.820190; 

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println("Memulai pembacaan HX711...");

  LoadCell.begin();
  LoadCell.start(2000, true);

  if (LoadCell.getTareTimeoutFlag()) {
    Serial.println("Timeout! Cek koneksi HX711.");
    while (1);
  }

  // Set faktor kalibrasi
  LoadCell.setCalFactor(calibrationFactor);

  Serial.println("Tare selesai. Siap membaca berat...");
}

void loop() {
  static unsigned long lastPrint = 0;

  // 🔥 WAJIB dipanggil terus
  LoadCell.update();

  // Ambil data tiap 200 ms
  if (millis() - lastPrint > 200) {
    float weight = LoadCell.getData();

    Serial.print("Berat: ");
    Serial.print(weight, 2);
    Serial.println(" g");

    lastPrint = millis();
  }
}