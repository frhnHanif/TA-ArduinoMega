#include <Arduino.h>
#include "HX711_ADC.h"

const int HX711_DOUT = 2;
const int HX711_SCK = 4;

float currentCalibrationFactor = 106.367408; // Angka default jika terjadi salah input
const float KNOWN_WEIGHT = 5000.0;
const int STABILIZATION_SAMPLES = 100;
const int MEASUREMENT_SAMPLES = 200;
const float STABILITY_THRESHOLD = 10.0;
const unsigned long MODE_SELECTION_TIMEOUT_MS = 8000;

HX711_ADC LoadCell(HX711_DOUT, HX711_SCK);c
enum BootMode {
  MODE_READ,
  MODE_CALIBRATE
};

BootMode activeMode = MODE_READ;

void initializeLoadCell(bool tareOnStart);
BootMode selectBootMode();
void runCalibrationMode();
void runReadMode();
void performMeasurement(float &sum, int &validSamples);
void calculateResults(float sum, int validSamples);

void setup() {
  Serial.begin(115200);
  Serial.println();
  Serial.println("==============================================");
  Serial.println("   Program HX711 - Alat Tester Load Cell");
  Serial.println("==============================================");

  activeMode = selectBootMode();
  initializeLoadCell(true);

  if (activeMode == MODE_CALIBRATE) {
    runCalibrationMode();
  } else {
    runReadMode();
  }
}

void loop() {
  if (activeMode != MODE_READ) {
    return;
  }

  static bool newDataReady = false;
  static unsigned long lastPrintTime = 0;
  const unsigned long printIntervalMs = 250;

  if (LoadCell.update()) {
    newDataReady = true;
  }

  if (newDataReady && millis() - lastPrintTime >= printIntervalMs) {
    float weightInGrams = LoadCell.getData();
    float weightInKg = weightInGrams / 1000.0;

    // Filter angka mendekati 0 (0.05 kg / 50 gram) agar stabil
    if (weightInKg < 0.05 && weightInKg > -0.05) {
      weightInKg = 0.00;
    }

    // Output hanya dalam x.xx kg
    Serial.print("Berat: ");
    Serial.print(weightInKg, 2);
    Serial.println(" kg");

    newDataReady = false;
    lastPrintTime = millis();
  }
}

void initializeLoadCell(bool tareOnStart) {
  LoadCell.begin();
  Serial.println("Memulai timbangan...");
  LoadCell.start(2000, tareOnStart);

  if (LoadCell.getTareTimeoutFlag()) {
    Serial.println("Timeout. Cek koneksi HX711.");
    while (1) {
    }
  }
}

BootMode selectBootMode() {
  Serial.println("Pilih mode boot:");
  Serial.println("  c = kalibrasi load cell baru");
  Serial.println("  r = baca berat (dengan input faktor)");
  Serial.print("Kirim pilihan dalam ");
  Serial.print(MODE_SELECTION_TIMEOUT_MS / 1000);
  Serial.println(" detik...");

  unsigned long startTime = millis();
  while (millis() - startTime < MODE_SELECTION_TIMEOUT_MS) {
    if (Serial.available() > 0) {
      char choice = Serial.read();
      while (Serial.available() > 0) {
        Serial.read(); // Bersihkan sisa buffer
      }

      if (choice == 'c' || choice == 'C') {
        Serial.println("Mode kalibrasi dipilih.");
        return MODE_CALIBRATE;
      }

      if (choice == 'r' || choice == 'R') {
        Serial.println("Mode baca dipilih.");
        return MODE_READ;
      }
    }
  }

  Serial.println("Tidak ada input. Default ke mode baca.");
  return MODE_READ;
}

void runCalibrationMode() {
  LoadCell.setCalFactor(1.0);
  Serial.println("Faktor kalibrasi sementara diatur ke 1.0.");
  Serial.println();
  Serial.print("Letakkan beban acuan: ");
  Serial.print(KNOWN_WEIGHT, 0);
  Serial.println(" g");
  
  Serial.println("Pengambilan data akan dimulai dalam 10 detik...");
  for (int i = 10; i > 0; i--) {
    Serial.print("Mulai dalam ");
    Serial.print(i);
    Serial.println(" detik...");
    delay(1000);
  }

  Serial.println("Menunggu stabilisasi...");

  float lastReading = 0.0;
  int stableCount = 0;

  for (int i = 0; i < STABILIZATION_SAMPLES; i++) {
    LoadCell.update();
    float reading = LoadCell.getData();

    Serial.print("Stabilisasi ");
    Serial.print(i + 1);
    Serial.print("/");
    Serial.print(STABILIZATION_SAMPLES);
    Serial.print(": ");
    Serial.println(reading, 0);

    if (i > 0 && abs(reading - lastReading) < STABILITY_THRESHOLD) {
      stableCount++;
    } else {
      stableCount = 0;
    }

    lastReading = reading;

    if (stableCount >= 5) {
      Serial.println("Sinyal stabil, lanjut pengukuran.");
      break;
    }

    delay(100);
  }

  for (int i = 0; i < 5; i++) {
    LoadCell.update();
    delay(50);
  }

  float sum = 0.0;
  int validSamples = 0;
  performMeasurement(sum, validSamples);
  calculateResults(sum, validSamples);
}

void performMeasurement(float &sum, int &validSamples) {
  Serial.println("Mengambil sampel kalibrasi...");
  Serial.println("----------------------------------------------");

  float previousReading = 0.0;
  for (int i = 0; i < MEASUREMENT_SAMPLES; i++) {
    LoadCell.update();
    float reading = LoadCell.getData();
    sum += reading;
    validSamples++;

    Serial.print("Data ");
    Serial.print(i + 1);
    Serial.print("/");
    Serial.print(MEASUREMENT_SAMPLES);
    Serial.print(": ");
    Serial.print(reading, 0);

    if (i > 0) {
      float change = abs(reading - previousReading);
      if (change < 10.0) {
        Serial.print(" stable");
      } else if (change < 50.0) {
        Serial.print(" medium");
      }
    }

    previousReading = reading;
    Serial.println();
    delay(80);
  }
}

void calculateResults(float sum, int validSamples) {
  float avg = sum / validSamples;
  float calibrationFactor = avg / KNOWN_WEIGHT;

  Serial.println("----------------------------------------------");
  Serial.println("HASIL KALIBRASI");
  Serial.println("----------------------------------------------");
  Serial.print("Jumlah sampel valid: ");
  Serial.println(validSamples);
  Serial.print("Rata-rata nilai mentah: ");
  Serial.println(avg, 3);
  Serial.print("Berat acuan: ");
  Serial.print(KNOWN_WEIGHT, 0);
  Serial.println(" g");
  Serial.print("Faktor kalibrasi: ");
  Serial.println(calibrationFactor, 6);

  Serial.println("----------------------------------------------");
  Serial.println("Validasi dengan faktor baru...");
  LoadCell.setCalFactor(calibrationFactor);
  delay(500);

  float validationSum = 0.0;
  const int validationSamples = 200;
  for (int i = 0; i < validationSamples; i++) {
    LoadCell.update();
    validationSum += LoadCell.getData();
    delay(50);
  }

  float validationAvg = validationSum / validationSamples;
  float error = abs(validationAvg - KNOWN_WEIGHT);
  float errorPercent = (error / KNOWN_WEIGHT) * 100.0;

  Serial.print("Berat terukur setelah kalibrasi: ");
  Serial.print(validationAvg, 2);
  Serial.println(" g");
  Serial.print("Error: ");
  Serial.print(error, 2);
  Serial.print(" g (");
  Serial.print(errorPercent, 2);
  Serial.println("%)");

  Serial.println("----------------------------------------------");
  if (errorPercent < 0.5) {
    Serial.println("Kalibrasi sangat akurat.");
  } else if (errorPercent < 1.0) {
    Serial.println("Kalibrasi berhasil.");
  } else if (errorPercent < 2.0) {
    Serial.println("Kalibrasi cukup akurat.");
  } else {
    Serial.println("Kalibrasi perlu diperbaiki.");
  }

  Serial.println("----------------------------------------------");
  Serial.println("COPY ANGKA DI BAWAH INI UNTUK LOAD CELL INI:");
  Serial.println(calibrationFactor, 6);
  Serial.println("----------------------------------------------");
  Serial.println("Selesai. Silakan reset Arduino untuk masuk ke Mode Baca.");
}

void runReadMode() {
  Serial.println();
  Serial.println(">>> MODE BACA AKTIF <<<");
  Serial.println("Silakan PASTE atau KETIK faktor kalibrasi untuk load cell ini...");
  
  // Bersihkan buffer serial sebelum menunggu input
  while (Serial.available() > 0) { Serial.read(); }

  // Tunggu sampai ada input dari user
  while (Serial.available() == 0) {
    // Arduino akan diam di sini sampai kamu menekan Enter di Serial Monitor
  }

  // Ambil angka desimal yang dimasukkan user
  float inputFactor = Serial.parseFloat();
  
  // Bersihkan sisa karakter (seperti Enter/Newline)
  while (Serial.available() > 0) { Serial.read(); }

  // Validasi input
  if (inputFactor != 0.0) {
    currentCalibrationFactor = inputFactor;
    Serial.print("✅ Faktor kalibrasi berhasil diatur ke: ");
    Serial.println(currentCalibrationFactor, 6);
  } else {
    Serial.print("⚠️ Input tidak valid! Menggunakan default: ");
    Serial.println(currentCalibrationFactor, 6);
  }

  LoadCell.setCalFactor(currentCalibrationFactor);
  Serial.println("----------------------------------------------");
  Serial.println("Timbangan siap digunakan!");
  Serial.println("----------------------------------------------");
  delay(1000); // Beri jeda sedikit sebelum mulai membaca
}